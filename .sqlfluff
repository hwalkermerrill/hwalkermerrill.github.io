[sqlfluff]
dialect = postgres
large_file_skip_byte_limit = 0
max_line_length = 200
indent_unit = tab
tab_space_size = 2

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 2
indented_joins = True
indented_using_on = True
indented_on_contents = True
implicit_indents = allow

[sqlfluff:layout:type:values_clause]
# Force the values to start on a new line if they aren't already
line_position = alone

[sqlfluff:layout:type:values_clause_row]
# Specifically target the rows within the VALUES clause
line_position = alone

[sqlfluff:layout:type:bracketed]
# This ensures the (1, ...) rows are treated as indented blocks
line_position = alone
spacing_before = single 

[rule_L010]
capitalisation_policy = upper

[rule_L014]
extended_capitalisation_policy = upper

[rule_L029]
unquoted_identifiers_policy = consistent

[rule_L034]
force_enable = true

[rule_L036]
force_enable = true

[rule_L039]
select_clause_trailing_comma = forbid
