[sqlfluff]
dialect = postgres
large_file_skip_byte_limit = 0
max_line_length = 200
indent_unit = tab
tab_space_size = 2

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 2
implicit_indents = require
indented_joins = True
indented_using_on = True
indented_on_contents = True
indented_then = True
indented_then_contents = True
indented_constraints = True

[rule_L010]
capitalisation_policy = upper

[rule_L014]
extended_capitalisation_policy = upper

[rule_L029]
unquoted_identifiers_policy = consistent

[rule_L034]
force_enable = true

[rule_L036]
force_enable = true

[rule_L039]
select_clause_trailing_comma = forbid
