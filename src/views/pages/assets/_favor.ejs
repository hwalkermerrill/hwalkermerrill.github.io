<% if (favor && favor.length > 0) { %>
<h2>Favors</h2>

<div>
  <% favor.forEach(f => { %>
  <ul class="toggleLiVis" style="list-style-type: none;">
    <li><b>Click to View Favor: <%= f.item_name %></b></li>

    <li style="display:none;"><b><i><%= f.item_name %></i></b></li>

    <% if (f.description) { %>
    <li style="display:none;"><%- f.description %></li>
    <% } %>

    <% if (f.ability) { %>
    <li style="display:none;"><%- f.ability %></li>
    <% } %>

    <li style="display:none;"><br><i>&nbsp;&nbsp;~ Click to hide this favor...</i></li>
    <li class="clearfix" style="display:none;"></li>
  </ul>
  <% }) %>
</div>
<% } %>