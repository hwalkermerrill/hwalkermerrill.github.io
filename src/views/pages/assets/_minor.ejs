<% if (minor && minor.length > 0) { %>
<h2>Minor Items</h2>
<p>These items function as expected.</p>

<div>
  <% minor.forEach(m => { %>
  <ul class="toggleLiVis" style="list-style-type: none;">
    <li><b>Click to Identify <%= m.item_name %></b></li>

    <li style="display:none;"><b><i><%= m.item_name %></i></b></li>

    <% if (m.description) { %>
    <li style="display:none;"><%- m.description %></li>
    <% } %>

    <% if (m.ability) { %>
    <li style="display:none;"><%- m.ability %></li>
    <% } %>

    <li style="display:none;"><br><i>&nbsp;&nbsp;~ Click to put <%= m.item_name %> away...</i></li>
    <li class="clearfix" style="display:none;"></li>
  </ul>
  <% }) %>
</div>
<% } %>