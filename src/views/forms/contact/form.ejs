<%- include("../../partials/header") %>
<main>
	<h1>Contact Us</h1>
	<p>
		Have questions or feedback? Send us a message using the form below and we'll get back to you as soon as possible.
	</p>
	<p class="<%= activePage === 'contact' ? 'active' : '' %>">
		<a href="/contact/responses">CLICK HERE to view all responses we've received so far.</a>
		We take your feedback seriously and will review each submission carefully.
	</p>

	<form method="POST" action="/contact" class="contact-form">
		<!-- DIV ORDER: Subject, Message, Submit button -->
		<div class="form-group">
			<label for="subject">Subject</label>
			<input type="text" id="subject" name="subject" minlength="2" placeholder="What is this message about?" required>
		</div>

		<div class="form-group">
			<label for="message">Message</label>
			<textarea id="message" name="message" rows="6" minlength="10"
				placeholder="Please provide details about your question or feedback..." required></textarea>
		</div>

		<button type="submit">Send Message</button>
	</form>
</main>
<%- include("../../partials/footer") %>