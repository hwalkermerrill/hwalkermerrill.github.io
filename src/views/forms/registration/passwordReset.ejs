<%- include("../../partials/header") %>

<main>
  <h1>Password Reset Requests</h1>

  <!-- Display password reset requests -->
  <% if (requests && requests.length > 0) { %>
  <table>
    <tr>
      <th>User</th>
      <th>Username</th>
      <th>Status</th>
      <th>Requested At</th>
      <th>Reset Code</th>
      <th>Actions</th>
    </tr>
    <% requests.forEach(r => { %>
    <tr>
      <td><%= r.full_name %></td>
      <td><%= r.username %></td>
      <td><%= r.status %></td>
      <td><%= r.requested_at %></td>
      <td><%= r.reset_code || '-' %></td>
      <td>
        <% if (r.status === 'submitted') { %>
        <form method="POST" action="/admin/password-resets/<%= r.id %>/approve" style="display:inline;">
          <button type="submit">Approve</button>
        </form>
        <form method="POST" action="/admin/password-resets/<%= r.id %>/deny" style="display:inline;">
          <button type="submit">Deny</button>
        </form>
        <% } %>
      </td>
    </tr>
    <% }); %>
  </table>

  <!-- If No Requests -->
  <% } else { %>
  <p>No password reset requests.</p>
  <% } %>
</main>

<%- include("../../partials/footer") %>