<%- include("../../partials/header") %>
<main>
	<h1><%= title %></h1>
	<p>
		Register for a new account by providing your information below. All fields are required and passwords must meet
		security requirements.
	</p>
	<p class="<%= activePage === 'registration' ? 'active' : '' %>">
		<a href="/register/list">CLICK HERE to view all registered users.</a>
	</p>

	<form method="POST" action="/register" class="registration-form">
		<!-- DIV ORDER: Name, Invite Code, Username, Username Confirm, Password, Password Confirm, Submit button -->
		<div class="form-group">
			<label for="name">Name</label>
			<input type="text" id="name" name="name" minlength="2" placeholder="Enter your full name" required>
		</div>

		<div class="form-group">
			<label for="inviteCode">Invite Code</label>
			<input type="text" id="inviteCode" name="inviteCode" required
				placeholder="Enter the invitation code provided by the GM">
		</div>

		<div class="form-group">
			<label for="username">Username</label>
			<input type="text" id="username" name="username" minlength="2" placeholder="Enter a username" required>
		</div>

		<div class="form-group">
			<label for="usernameConfirm">Confirm Username</label>
			<input type="text" id="usernameConfirm" name="usernameConfirm" required>
		</div>

		<div class="form-group">
			<label for="password">Password</label>
			<input type="password" id="password" name="password" minlength="8" required
				pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*">
			<div class="help-text">Must be at least 8 characters with a number and special character</div>
		</div>

		<div class="form-group">
			<label for="passwordConfirm">Confirm Password</label>
			<input type="password" id="passwordConfirm" name="passwordConfirm" minlength="8" required
				pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*">
		</div>

		<div class="form-group">
			<button type="submit">Create Account</button>
		</div>
	</form>
</main>
<%- include("../../partials/footer") %>